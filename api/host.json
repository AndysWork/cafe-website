{
    "version": "2.0",
    "logging": {
        "applicationInsights": {
            "samplingSettings": {
                "isEnabled": true,
                "excludedTypes": "Request"
            },
            "enableLiveMetricsFilters": true
        }
    },
    "extensions": {
        "http": {
            "routePrefix": "api"
        },
        "openApi": {
            "version": "v3",
            "forceHttps": false,
            "forceHttp": false
        }
    },
    "singleton": {
        "lockPeriod": "00:00:15",
        "listenerLockPeriod": "00:01:00",
        "lockAcquisitionTimeout": "00:01:00",
        "lockAcquisitionPollingInterval": "00:00:02"
    },
    "cors": {
        "allowedOrigins": [
            "http://localhost:4200",
            "https://*.azurewebsites.net",
            "https://*.azurestaticapps.net",
            "https://www.maataracafe.in",
            "https://maataracafe.in"
        ],
        "supportCredentials": true
    }
}